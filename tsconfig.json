{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",                     // Atualizado junto com o de baixo
    "moduleResolution": "nodenext",           // Faz a dupla perfeita sem avisos
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false
  }
}